{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-flash",
  "provider": {
    "deepseek": {
      "models": {
        "deepseek-v4-flash": {
          "options": {
            "reasoningEffort": "high"
          }
        }
      }
    }
  },
  "skills": {
    "paths": ["/workspace/.skills"]
  },
  "mcp": {
    "browser-use": {
      "type": "remote",
      "url": "https://api.browser-use.com/mcp",
      "headers": {
        "x-browser-use-api-key": "YOUR_BROWSER_USE_KEY_HERE"
      }
    },
    "browserbase": {
      "type": "local",
      "command": ["npx", "-y", "@browserbasehq/mcp-server-browserbase"],
      "env": {
        "BROWSERBASE_API_KEY": "YOUR_BROWSERBASE_KEY_HERE"
      }
    },
    "confluence": {
      "type": "local",
      "command": ["npx", "-y", "confluence-mcp-server"],
      "env": {
        "CONFLUENCE_API_TOKEN": "YOUR_CONFLUENCE_TOKEN_HERE",
        "CONFLUENCE_BASE_URL": "YOUR_CONFLUENCE_URL_HERE",
        "CONFLUENCE_EMAIL": "YOUR_EMAIL_HERE"
      },
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "duckduckgo": {
      "type": "local",
      "command": ["web-search-mcp"]
    },
    "evalview": {
      "type": "local",
      "command": ["python3", "-m", "evalview", "mcp", "serve"],
      "env": {
        "OPENAI_API_KEY": "YOUR_OPENAI_API_KEY_HERE"
      },
      "enabled": false
    },
    "exa-web-search": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "YOUR_EXA_API_KEY_HERE"
      },
      "enabled": false
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch", "--ignore-robots-txt"]
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/workspace/"]
    },
    "firecrawl": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_KEY}"
      }
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "jira": {
      "type": "local",
      "command": ["uvx", "mcp-atlassian==0.21.0"],
      "env": {
        "JIRA_API_TOKEN": "YOUR_JIRA_API_TOKEN_HERE",
        "JIRA_EMAIL": "YOUR_JIRA_EMAIL_HERE",
        "JIRA_URL": "YOUR_JIRA_URL_HERE"
      },
      "enabled": false
    },
    "magic": {
      "type": "local",
      "command": ["npx", "-y", "@magicuidesign/mcp@latest"]
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": false
    },
    "omega-memory": {
      "type": "local",
      "command": ["/workspace/.venv/bin/omega", "serve"]
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp", "--browser", "chrome"]
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "supabase": {
      "type": "local",
      "command": ["npx", "-y", "@supabase/mcp-server-supabase@latest", "--project-ref=YOUR_PROJECT_REF"],
      "enabled": false
    }
  }
}
